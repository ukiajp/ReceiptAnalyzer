# Google Cloud認証情報パス
GOOGLE_CREDENTIALS_PATH=google-credentials.json

# Ollama設定
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_LLM_MODEL=llama3.2:3b

# ディレクトリ設定
DATASET_DIR=dataset
LOG_DIR=logs
OUTPUT_DIR=output

# 処理設定
LLM_TEMPERATURE=0.1
MAX_RETRIES=3
TIMEOUT_SECONDS=60

# ログ設定
LOG_LEVEL=INFO
LOG_FILE=receipt_analyzer.log

# 出力設定
SAVE_RAW_OUTPUT=true
